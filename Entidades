{
  "name": "Appointment",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "ID do cliente"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente (desnormalizado)"
    },
    "barber_id": {
      "type": "string",
      "description": "ID do barbeiro"
    },
    "barber_name": {
      "type": "string",
      "description": "Nome do barbeiro (desnormalizado)"
    },
    "service_name": {
      "type": "string",
      "description": "Nome do servi\u00e7o"
    },
    "price": {
      "type": "number",
      "description": "Pre\u00e7o cobrado"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Data do agendamento"
    },
    "time": {
      "type": "string",
      "description": "Hor\u00e1rio do agendamento (HH:mm)"
    },
    "duration": {
      "type": "number",
      "description": "Dura\u00e7\u00e3o em minutos"
    },
    "status": {
      "type": "string",
      "enum": [
        "scheduled",
        "completed",
        "cancelled",
        "no_show"
      ],
      "default": "scheduled",
      "description": "Status do agendamento"
    },
    "coupon_code": {
      "type": "string",
      "description": "Cupom aplicado"
    },
    "discount": {
      "type": "number",
      "default": 0,
      "description": "Valor do desconto aplicado"
    },
    "final_price": {
      "type": "number",
      "description": "Pre\u00e7o final ap\u00f3s desconto"
    },
    "notes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es"
    }
  },
  "required": [
    "client_id",
    "client_name",
    "service_name",
    "price",
    "date",
    "time"
  ]
}
