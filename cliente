{
  "name": "Client",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome completo do cliente"
    },
    "phone": {
      "type": "string",
      "description": "Telefone do cliente"
    },
    "email": {
      "type": "string",
      "description": "Email do cliente"
    },
    "status": {
      "type": "string",
      "enum": [
        "vip",
        "regular",
        "at_risk",
        "inactive"
      ],
      "default": "regular",
      "description": "Classifica\u00e7\u00e3o autom\u00e1tica do cliente"
    },
    "last_visit": {
      "type": "string",
      "format": "date",
      "description": "Data da \u00faltima visita"
    },
    "total_visits": {
      "type": "number",
      "default": 0,
      "description": "Total de visitas"
    },
    "total_spent": {
      "type": "number",
      "default": 0,
      "description": "Total gasto pelo cliente"
    },
    "notes": {
      "type": "string",
      "description": "Observa\u00e7\u00f5es sobre o cliente"
    }
  },
  "required": [
    "name",
    "phone"
  ]
}
