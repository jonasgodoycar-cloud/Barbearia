{
  "name": "Coupon",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "C\u00f3digo do cupom"
    },
    "discount_type": {
      "type": "string",
      "enum": [
        "percentage",
        "fixed"
      ],
      "default": "percentage",
      "description": "Tipo de desconto"
    },
    "discount_value": {
      "type": "number",
      "description": "Valor do desconto"
    },
    "usage_limit": {
      "type": "number",
      "description": "Limite de usos"
    },
    "times_used": {
      "type": "number",
      "default": 0,
      "description": "Vezes j\u00e1 utilizado"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Se o cupom est\u00e1 ativo"
    },
    "expires_at": {
      "type": "string",
      "format": "date",
      "description": "Data de expira\u00e7\u00e3o"
    }
  },
  "required": [
    "code",
    "discount_type",
    "discount_value"
  ]
}
